{
  "version": 2,
  "installCommand": "npm install --prefix frontend-pwa",
  "buildCommand": "npm run build --prefix frontend-pwa",
  "outputDirectory": "frontend-pwa/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://rural-health-triage-backend.onrender.com/api/$1"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
